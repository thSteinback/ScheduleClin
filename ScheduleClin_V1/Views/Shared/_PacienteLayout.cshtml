<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – ScheduleClin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@3.33.0/dist/tabler-icons.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html, body { height: 100%; margin: 0; font-family: 'Inter', system-ui, sans-serif; background: #f4f6fb; }

        .adm-shell { display: flex; height: 100vh; overflow: hidden; }

        .adm-sidebar {
            width: 240px; min-width: 240px;
            background: #fff;
            border-right: 1px solid #e8eaf0;
            display: flex; flex-direction: column;
            overflow-y: auto;
        }
        .adm-logo {
            padding: 20px 20px 18px;
            display: flex; align-items: center; gap: 10px;
            border-bottom: 1px solid #e8eaf0;
        }
        .adm-logo-icon {
            width: 36px; height: 36px; border-radius: 8px;
            background: #be185d; display: flex; align-items: center;
            justify-content: center; color: #fff; font-size: 18px;
        }
        .adm-logo-text strong { display: block; font-size: 14px; font-weight: 600; color: #111827; }
        .adm-logo-text span   { font-size: 12px; color: #6b7280; }

        .adm-nav { padding: 12px 0; flex: 1; }
        .adm-nav-link {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 20px; color: #4b5563;
            font-size: 14px; text-decoration: none;
            border-radius: 0; transition: all .15s;
            border-left: 3px solid transparent;
        }
        .adm-nav-link:hover  { color: #be185d; background: #fdf2f8; }
        .adm-nav-link.active { color: #be185d; background: #fdf2f8; border-left-color: #be185d; font-weight: 500; }
        .adm-nav-link .ti    { font-size: 18px; }

        .adm-sidebar-footer {
            padding: 16px 20px;
            border-top: 1px solid #e8eaf0;
        }
        .adm-user { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
        .adm-avatar {
            width: 32px; height: 32px; border-radius: 50%;
            background: #be185d; color: #fff;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 600; flex-shrink: 0;
        }
        .adm-user strong { display: block; font-size: 13px; color: #111827; }
        .adm-user span   { font-size: 11px; color: #6b7280; }
        .adm-logout {
            display: flex; align-items: center; gap: 6px;
            color: #6b7280; font-size: 13px; text-decoration: none;
            padding: 0; background: none; border: none; cursor: pointer;
        }
        .adm-logout:hover { color: #ef4444; }

        .adm-main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
        .adm-content { flex: 1; overflow-y: auto; padding: 32px 36px; }

        .adm-page-title { font-size: 22px; font-weight: 600; color: #111827; margin-bottom: 4px; }
        .adm-page-sub   { font-size: 14px; color: #6b7280; margin-bottom: 24px; }

        .adm-card {
            background: #fff; border: 1px solid #e8eaf0;
            border-radius: 12px; overflow: hidden; margin-bottom: 16px;
        }
        .adm-table { width: 100%; border-collapse: collapse; font-size: 14px; }
        .adm-table th {
            padding: 11px 16px; text-align: left;
            font-size: 11px; font-weight: 600; color: #9ca3af;
            text-transform: uppercase; letter-spacing: .5px;
            border-bottom: 1px solid #f3f4f6;
        }
        .adm-table td {
            padding: 13px 16px; border-bottom: 1px solid #f3f4f6;
            color: #374151; vertical-align: middle;
        }
        .adm-table tr:last-child td { border-bottom: none; }
        .adm-table tr:hover td { background: #fafafa; }

        .adm-user-cell { display: flex; align-items: center; gap: 10px; }
        .adm-user-cell .av {
            width: 34px; height: 34px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 600; color: #fff; flex-shrink: 0;
        }
        .adm-user-cell .info strong { display: block; font-size: 14px; color: #111827; }
        .adm-user-cell .info span   { font-size: 12px; color: #9ca3af; }

        .adm-search-wrap { display: flex; gap: 10px; margin-bottom: 20px; }
        .adm-search {
            flex: 1; display: flex; align-items: center; gap: 8px;
            background: #fff; border: 1px solid #e8eaf0;
            border-radius: 8px; padding: 8px 14px;
        }
        .adm-search input { border: none; outline: none; font-size: 14px; width: 100%; color: #374151; }
        .adm-search .ti { color: #9ca3af; font-size: 18px; }

        .adm-input {
            width: 100%; padding: 9px 12px;
            border: 1px solid #e8eaf0; border-radius: 8px;
            font-size: 14px; color: #374151; background: #fff;
        }
        .adm-input:focus { outline: none; border-color: #be185d; box-shadow: 0 0 0 3px rgba(190,24,93,.12); }

        .adm-badge {
            display: inline-flex; align-items: center;
            padding: 3px 10px; border-radius: 20px;
            font-size: 12px; font-weight: 500;
        }
        .adm-badge-blue   { background: #dbeafe; color: #1d4ed8; }
        .adm-badge-teal   { background: #ccfbf1; color: #0f766e; }
        .adm-badge-purple { background: #ede9fe; color: #6d28d9; }
        .adm-badge-gray   { background: #f1f5f9; color: #475569; }
        .adm-badge-red    { background: #fee2e2; color: #b91c1c; }
        .adm-badge-orange { background: #ffedd5; color: #c2410c; }
        .adm-badge-green  { background: #d1fae5; color: #047857; }

        .adm-icon-btn {
            width: 32px; height: 32px; border-radius: 8px;
            border: 1px solid #e8eaf0; background: #fff;
            cursor: pointer; display: inline-flex; align-items: center;
            justify-content: center; color: #6b7280; font-size: 16px;
            text-decoration: none; transition: all .15s;
        }
        .adm-icon-btn:hover { background: #f3f4f6; color: #111827; }

        .adm-btn {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 8px 16px; border-radius: 8px; font-size: 14px;
            cursor: pointer; border: 1px solid #e8eaf0;
            background: #fff; color: #374151; text-decoration: none;
            transition: background .15s; font-weight: 500;
        }
        .adm-btn:hover { background: #f3f4f6; }
        .adm-btn-danger { background: #fee2e2; color: #b91c1c; border-color: #fecaca; }
        .adm-btn-danger:hover { background: #fecaca; }

        .adm-modal-bg {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,.35); z-index: 200;
            align-items: center; justify-content: center;
        }
        .adm-modal-bg.open { display: flex; }
        .adm-modal {
            background: #fff; border-radius: 14px;
            width: 440px; max-height: 90vh; overflow-y: auto;
            padding: 28px;
        }
        .adm-modal-head {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 22px;
        }
        .adm-modal-head h3 { font-size: 16px; font-weight: 600; color: #111827; margin: 0; }
        .adm-modal-close {
            background: none; border: none; cursor: pointer;
            color: #9ca3af; font-size: 20px;
        }
        .adm-modal-close:hover { color: #374151; }

        .adm-field { margin-bottom: 16px; }
        .adm-field label {
            display: block; font-size: 11px; font-weight: 600;
            color: #6b7280; text-transform: uppercase; letter-spacing: .4px;
            margin-bottom: 5px;
        }
        .adm-modal-footer { display: flex; gap: 10px; margin-top: 8px; }
        .adm-modal-footer .adm-btn { flex: 1; justify-content: center; }

        .adm-detail-row { display: flex; gap: 12px; padding: 10px 0; border-bottom: 1px solid #f3f4f6; }
        .adm-detail-row:last-child { border-bottom: none; }
        .adm-detail-label { font-size: 12px; color: #9ca3af; font-weight: 500; width: 110px; flex-shrink: 0; }
        .adm-detail-value { font-size: 14px; color: #111827; }

        .adm-toast {
            position: fixed; bottom: 24px; right: 24px; z-index: 9999;
            background: #111827; color: #fff; padding: 12px 18px;
            border-radius: 8px; font-size: 13px;
            display: none; align-items: center; gap: 8px;
        }
        .adm-toast.show { display: flex; }
    </style>
</head>
<body>
    <partial name="_CsrfFetch" />
<div class="adm-shell">

    <aside class="adm-sidebar">
        <div class="adm-logo">
            <div class="adm-logo-icon"><i class="ti ti-calendar-heart"></i></div>
            <div class="adm-logo-text">
                <strong>Clínica</strong>
                <span>Bem-Estar</span>
            </div>
        </div>

        <nav class="adm-nav">
            <a class="adm-nav-link @(ViewData["ActiveMenu"]?.ToString()=="consultas"?"active":"")"
               asp-controller="Paciente" asp-action="Consultas">
                <i class="ti ti-calendar-check"></i> Minhas Consultas
            </a>
            <a class="adm-nav-link @(ViewData["ActiveMenu"]?.ToString()=="historico"?"active":"")"
               asp-controller="Paciente" asp-action="Historico">
                <i class="ti ti-history"></i> Histórico
            </a>
        </nav>

        <div class="adm-sidebar-footer">
            <div class="adm-user">
                <div class="adm-avatar">
                    @(User.Identity?.Name?.Length >= 2 ? User.Identity.Name.Substring(0,2).ToUpper() : "PA")
                </div>
                <div>
                    <strong>@User.Identity?.Name</strong>
                    <span>Paciente</span>
                </div>
            </div>
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="adm-logout">
                    <i class="ti ti-logout"></i> Sair
                </button>
            </form>
        </div>
    </aside>

    <div class="adm-main">
        <div class="adm-content">
            @RenderBody()
        </div>
    </div>

</div>

<div class="adm-toast" id="adm-toast"></div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function openModal(id)  { document.getElementById(id).classList.add('open'); }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }

    function showToast(msg, ok = true) {
        const t = document.getElementById('adm-toast');
        t.textContent = msg;
        t.style.background = ok ? '#111827' : '#b91c1c';
        t.classList.add('show');
        clearTimeout(t._timeoutId);
        t._timeoutId = setTimeout(() => t.classList.remove('show'), 3000);
    }

    document.querySelectorAll('.adm-modal-bg').forEach(bg =>
        bg.addEventListener('click', e => { if (e.target === bg) bg.classList.remove('open'); })
    );

    const COLORS = ['#2563eb','#0f766e','#7c3aed','#b45309','#be185d','#0369a1'];
    function avatarColor(name) {
        let h = 0;
        for (let c of (name||'')) h = (h*31 + c.charCodeAt(0)) & 0xffff;
        return COLORS[h % COLORS.length];
    }

    const STATUS_BADGE = {
        'Pendente':                 'adm-badge-orange',
        'Confirmada':               'adm-badge-green',
        'Reagendamento Solicitado': 'adm-badge-purple',
        'Cancelada':                'adm-badge-red',
        'Finalizado':               'adm-badge-blue',
    };
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
