<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – ScheduleClin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@3.33.0/dist/tabler-icons.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html, body { height: 100%; margin: 0; font-family: 'Inter', system-ui, sans-serif; background: #f4f6fb; }

        /* ── shell ── */
        .adm-shell { display: flex; height: 100vh; overflow: hidden; }

        /* ── sidebar ── */
        .adm-sidebar {
            width: 240px; min-width: 240px;
            background: #fff;
            border-right: 1px solid #e8eaf0;
            display: flex; flex-direction: column;
            overflow-y: auto;
        }
        .adm-logo {
            padding: 20px 20px 18px;
            display: flex; align-items: center; gap: 10px;
            border-bottom: 1px solid #e8eaf0;
        }
        .adm-logo-icon {
            width: 36px; height: 36px; border-radius: 8px;
            background: #2563eb; display: flex; align-items: center;
            justify-content: center; color: #fff; font-size: 18px;
        }
        .adm-logo-text strong { display: block; font-size: 14px; font-weight: 600; color: #111827; }
        .adm-logo-text span   { font-size: 12px; color: #6b7280; }

        .adm-nav { padding: 12px 0; flex: 1; }
        .adm-nav-link {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 20px; color: #4b5563;
            font-size: 14px; text-decoration: none;
            border-radius: 0; transition: all .15s;
            border-left: 3px solid transparent;
        }
        .adm-nav-link:hover  { color: #2563eb; background: #eff6ff; }
        .adm-nav-link.active { color: #2563eb; background: #eff6ff; border-left-color: #2563eb; font-weight: 500; }
        .adm-nav-link .ti    { font-size: 18px; }

        .adm-sidebar-footer {
            padding: 16px 20px;
            border-top: 1px solid #e8eaf0;
        }
        .adm-user { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
        .adm-avatar {
            width: 32px; height: 32px; border-radius: 50%;
            background: #6b7280; color: #fff;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 600; flex-shrink: 0;
        }
        .adm-user strong { display: block; font-size: 13px; color: #111827; }
        .adm-user span   { font-size: 11px; color: #6b7280; }
        .adm-logout {
            display: flex; align-items: center; gap: 6px;
            color: #6b7280; font-size: 13px; text-decoration: none;
            padding: 0;  background: none; border: none; cursor: pointer;
        }
        .adm-logout:hover { color: #ef4444; }

        /* ── main ── */
        .adm-main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

        /* ── content ── */
        .adm-content { flex: 1; overflow-y: auto; padding: 32px 36px; }

        .adm-page-title   { font-size: 22px; font-weight: 600; color: #111827; margin-bottom: 4px; }
        .adm-page-sub     { font-size: 14px; color: #6b7280; margin-bottom: 24px; }

        /* ── cards ── */
        .adm-card {
            background: #fff; border: 1px solid #e8eaf0;
            border-radius: 12px; overflow: hidden; margin-bottom: 16px;
        }

        /* badges */
        .adm-badge {
            display: inline-flex; align-items: center;
            padding: 3px 10px; border-radius: 20px;
            font-size: 12px; font-weight: 500;
        }
        .adm-badge-blue    { background: #dbeafe; color: #1d4ed8; }
        .adm-badge-teal    { background: #ccfbf1; color: #0f766e; }
        .adm-badge-purple  { background: #ede9fe; color: #6d28d9; }
        .adm-badge-gray    { background: #f1f5f9; color: #475569; }
        .adm-badge-red     { background: #fee2e2; color: #b91c1c; }
        .adm-badge-orange  { background: #ffedd5; color: #c2410c; }
        .adm-badge-green   { background: #d1fae5; color: #047857; }

        /* icon btn */
        .adm-icon-btn {
            width: 32px; height: 32px; border-radius: 8px;
            border: 1px solid #e8eaf0; background: #fff;
            cursor: pointer; display: inline-flex; align-items: center;
            justify-content: center; color: #6b7280; font-size: 16px;
            text-decoration: none; transition: all .15s;
        }
        .adm-icon-btn:hover { background: #f3f4f6; color: #111827; }

        /* btn */
        .adm-btn {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 8px 16px; border-radius: 8px; font-size: 14px;
            cursor: pointer; border: 1px solid #e8eaf0;
            background: #fff; color: #374151; text-decoration: none;
            transition: background .15s; font-weight: 500;
        }
        .adm-btn:hover { background: #f3f4f6; }
        .adm-btn-primary { background: #2563eb; color: #fff; border-color: #2563eb; }
        .adm-btn-primary:hover { background: #1d4ed8; color: #fff; }

        /* modal */
        .adm-modal-bg {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,.35); z-index: 200;
            align-items: center; justify-content: center;
        }
        .adm-modal-bg.open { display: flex; }
        .adm-modal {
            background: #fff; border-radius: 14px;
            width: 440px; max-height: 90vh; overflow-y: auto;
            padding: 28px;
        }
        .adm-modal-head {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 22px;
        }
        .adm-modal-head h3 { font-size: 16px; font-weight: 600; color: #111827; margin: 0; }
        .adm-modal-close {
            background: none; border: none; cursor: pointer;
            color: #9ca3af; font-size: 20px;
        }
        .adm-modal-close:hover { color: #374151; }

        /* toast */
        .adm-toast {
            position: fixed; bottom: 24px; right: 24px; z-index: 9999;
            background: #111827; color: #fff; padding: 12px 18px;
            border-radius: 8px; font-size: 13px;
            display: none; align-items: center; gap: 8px;
        }
        .adm-toast.show { display: flex; }
    </style>
</head>
<body>
<div class="adm-shell">

    <!-- SIDEBAR -->
    <aside class="adm-sidebar">
        <div class="adm-logo">
            <div class="adm-logo-icon"><i class="ti ti-calendar-event"></i></div>
            <div class="adm-logo-text">
                <strong>Clínica</strong>
                <span>Bem-Estar</span>
            </div>
        </div>

        <nav class="adm-nav">
            <a class="adm-nav-link @(ViewData["ActiveMenu"]?.ToString()=="agenda"?"active":"")"
               asp-controller="Psicologo" asp-action="Agenda">
                <i class="ti ti-calendar"></i> Minha Agenda
            </a>
        </nav>

        <div class="adm-sidebar-footer">
            <div class="adm-user">
                <div class="adm-avatar" style="background:#0f766e">
                    @(User.Identity?.Name?.Length >= 2 ? User.Identity.Name.Substring(0,2).ToUpper() : "PS")
                </div>
                <div>
                    <strong>@User.Identity?.Name</strong>
                    <span>Psicóloga(o)</span>
                </div>
            </div>
            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="adm-logout">
                    <i class="ti ti-logout"></i> Sair
                </button>
            </form>
        </div>
    </aside>

    <!-- MAIN -->
    <div class="adm-main">
        <div class="adm-content">
            @RenderBody()
        </div>
    </div>

</div>

<!-- toast global -->
<div class="adm-toast" id="adm-toast"></div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // helpers globais
    function openModal(id)  { document.getElementById(id).classList.add('open'); }
    function closeModal(id) { document.getElementById(id).classList.remove('open'); }

    function showToast(msg, ok = true) {
        const t = document.getElementById('adm-toast');
        t.textContent = msg;
        t.style.background = ok ? '#111827' : '#b91c1c';
        t.classList.add('show');
        setTimeout(() => t.classList.remove('show'), 3000);
    }

    // fechar modal clicando fora
    document.querySelectorAll('.adm-modal-bg').forEach(bg =>
        bg.addEventListener('click', e => { if (e.target === bg) bg.classList.remove('open'); })
    );

    // avatar color por iniciais
    const COLORS = ['#2563eb','#0f766e','#7c3aed','#b45309','#be185d','#0369a1'];
    function avatarColor(name) {
        let h = 0;
        for (let c of (name||'')) h = (h*31 + c.charCodeAt(0)) & 0xffff;
        return COLORS[h % COLORS.length];
    }
    document.querySelectorAll('[data-av-name]').forEach(el => {
        el.style.background = avatarColor(el.dataset.avName);
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
