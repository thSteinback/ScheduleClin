@{
    Layout = "~/Views/Shared/_PsicologoLayout.cshtml";
    ViewData["Title"]      = "Histórico";
    ViewData["ActiveMenu"] = "historico";
}

<div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:6px">
    <div>
        <div class="adm-page-title">Histórico de Consultas</div>
        <div class="adm-page-sub" id="hist-sub">Consultas realizadas ou passadas até agora, e finalizadas</div>
    </div>
</div>

<div class="adm-search-wrap">
    <div class="adm-search">
        <i class="ti ti-search"></i>
        <input type="text" id="hist-busca" placeholder="Buscar paciente..." oninput="filtrarHistorico()" />
    </div>
    <select class="adm-input" style="width:200px" id="hist-status" onchange="filtrarHistorico()">
        <option value="">Todos os status</option>
        <option>Pendente</option>
        <option>Confirmada</option>
        <option>Reagendamento Solicitado</option>
        <option>Finalizado</option>
        <option>Cancelada</option>
    </select>
</div>

<div class="adm-card">
    <table class="adm-table">
        <thead>
            <tr>
                <th>Paciente</th>
                <th>Data &amp; Hora</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody id="hist-tbody">
            <tr><td colspan="4" style="text-align:center;padding:32px;color:#9ca3af">Carregando...</td></tr>
        </tbody>
    </table>
</div>

@await Html.PartialAsync("_ModalNovaConsulta")

@section Scripts {
<script>
    const initials = n => (n||'??').split(/\s+/).slice(0,2).map(p=>p[0]).join('').toUpperCase();

    let historicoConsultas = [];

    async function carregarHistorico() {
        try {
            const res = await fetch('/api/PsicologoAgenda/historico', { credentials: 'include' });
            historicoConsultas = res.ok ? await res.json() : [];
        } catch {
            historicoConsultas = [];
        }
        filtrarHistorico();
    }

    function filtrarHistorico() {
        const busca  = document.getElementById('hist-busca').value.toLowerCase();
        const status = document.getElementById('hist-status').value;

        const filtradas = historicoConsultas
            .filter(c => !busca || (c.pacienteNome || '').toLowerCase().includes(busca))
            .filter(c => !status || c.status === status);

        renderizarHistorico(filtradas);
    }

    function renderizarHistorico(lista) {
        const canceladas = lista.filter(c => c.status === 'Cancelada').length;
        const finalizadas = lista.filter(c => c.status === 'Finalizado').length;
        const reagendadas = lista.filter(c => c.status === 'Reagendamento Solicitado').length;

        document.getElementById('hist-sub').textContent =
            `${lista.length} consulta${lista.length !== 1 ? 's' : ''} no histórico` +
            (finalizadas ? ` · ${finalizadas} finalizada${finalizadas !== 1 ? 's' : ''}` : '') +
            (canceladas ? ` · ${canceladas} cancelada${canceladas !== 1 ? 's' : ''}` : '') +
            (reagendadas ? ` · ${reagendadas} reagendamento${reagendadas !== 1 ? 's' : ''}` : '');

        if (!lista.length) {
            document.getElementById('hist-tbody').innerHTML =
                `<tr><td colspan="4" style="text-align:center;padding:32px;color:#9ca3af">Nenhuma consulta no histórico.</td></tr>`;
            return;
        }

        const rows = lista.map(c => {
            const dt = new Date(c.scheduleDate);
            const dataHora = `${dt.toLocaleDateString('pt-BR')} <span style="color:#9ca3af">${dt.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})} · ${c.durationMinutes}min</span>`;
            const nome = c.pacienteNome || c.title;

            return `<tr>
                <td>
                    <div class="adm-user-cell">
                        <div class="av" style="background:${avatarColor(nome)}">${initials(nome)}</div>
                        <div class="info">
                            <strong>${nome}</strong>
                        </div>
                    </div>
                </td>
                <td>${dataHora}</td>
                <td><span class="adm-badge ${STATUS_BADGE[c.status] || 'adm-badge-gray'}">${c.status}</span></td>
                <td style="text-align:right">
                    <button class="adm-icon-btn" onclick='abrirDetalhesConsulta(${JSON.stringify(c).replace(/'/g, "&apos;")}, true)'>
                        <i class="ti ti-dots"></i>
                    </button>
                </td>
            </tr>`;
        });

        document.getElementById('hist-tbody').innerHTML = rows.join('');
    }

    (async () => {
        await carregarHistorico();
    })();
</script>
}
