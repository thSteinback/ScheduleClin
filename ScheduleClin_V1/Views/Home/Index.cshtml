@{
    ViewData["Title"] = "Início";
}
<div class="py-4">
    <h1 class="h3">ScheduleClin</h1>

    @if (TempData["Msg"] is string msg)
    {
        <div class="alert alert-success">@msg</div>
    }

    <p>Bem-vindo, <strong>@User.Identity?.Name</strong>.</p>
    <p>
        Perfis:
        <strong>
            @string.Join(", ", User.Claims
                .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role)
                .Select(c => c.Value))
        </strong>
    </p>

    <div class="d-flex gap-2 mt-3">
        <a class="btn btn-outline-secondary" asp-controller="Account" asp-action="ChangePassword">Trocar senha</a>
        <form asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="btn btn-outline-danger">Sair</button>
        </form>
    </div>
</div>
