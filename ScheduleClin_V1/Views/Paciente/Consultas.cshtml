@{
    Layout = "~/Views/Shared/_PacienteLayout.cshtml";
    ViewData["Title"]      = "Minhas Consultas";
    ViewData["ActiveMenu"] = "consultas";
}

<div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:6px">
    <div>
        <div class="adm-page-title">Minhas Consultas</div>
        <div class="adm-page-sub" id="pc-sub">Carregando...</div>
    </div>
    <button class="adm-btn adm-btn-primary" onclick="abrirNovaConsulta()">
        <i class="ti ti-plus"></i> Nova consulta
    </button>
</div>

<div class="adm-search-wrap">
    <div class="adm-search">
        <i class="ti ti-search"></i>
        <input type="text" id="pc-busca" placeholder="Buscar por psicólogo ou título..." oninput="filtrar()" />
    </div>
    <select class="adm-input" style="width:200px" id="pc-status" onchange="filtrar()">
        <option value="">Todos os status</option>
        <option>Pendente</option>
        <option>Confirmada</option>
        <option>Reagendamento Solicitado</option>
        <option>Finalizado</option>
        <option>Cancelada</option>
    </select>
</div>

<div class="adm-card">
    <table class="adm-table">
        <thead>
            <tr>
                <th>Psicólogo(a)</th>
                <th>Data &amp; Hora</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody id="pc-tbody">
            <tr><td colspan="4" style="text-align:center;padding:32px;color:#9ca3af">Carregando...</td></tr>
        </tbody>
    </table>
</div>

<!-- Modal Nova Consulta -->
<div class="adm-modal-bg" id="modal-nova">
    <div class="adm-modal">
        <div class="adm-modal-head">
            <h3>Nova Consulta</h3>
            <button class="adm-modal-close" onclick="closeModal('modal-nova')"><i class="ti ti-x"></i></button>
        </div>
        <div class="adm-field">
            <label>Psicólogo(a) *</label>
            <select class="adm-input" id="nova-psicologo">
                <option value="">Carregando...</option>
            </select>
        </div>
        <div class="adm-field">
            <label>Data *</label>
            <input type="text" class="adm-input" id="nova-data" placeholder="dd/mm/aaaa" maxlength="10" oninput="aplicarMascaraData(this)" autocomplete="off" />
        </div>
        <div class="adm-field">
            <label>Horário * <span style="color:#9ca3af;font-weight:400">(07:00–19:00)</span></label>
            <input type="time" class="adm-input" id="nova-hora" min="07:00" max="19:00" step="1800" />
        </div>
        <div class="adm-modal-footer">
            <button class="adm-btn" onclick="closeModal('modal-nova')">Cancelar</button>
            <button class="adm-btn adm-btn-primary" onclick="salvarConsulta()">Agendar</button>
        </div>
    </div>
</div>

<!-- Modal Detalhes -->
<div class="adm-modal-bg" id="modal-detalhe">
    <div class="adm-modal">
        <div class="adm-modal-head">
            <h3>Detalhes da Consulta</h3>
            <button class="adm-modal-close" onclick="closeModal('modal-detalhe')"><i class="ti ti-x"></i></button>
        </div>
        <div id="detalhe-corpo"></div>
        <div class="adm-modal-footer" id="detalhe-acoes" style="margin-top:20px"></div>
    </div>
</div>

@section Scripts {
<script>
    const initials = n => (n||'??').split(/\s+/).slice(0,2).map(p=>p[0]).join('').toUpperCase();

    let todas = [];

    async function carregar() {
        try {
            const res = await fetch('/api/PacienteAgenda', { credentials: 'include' });
            todas = res.ok ? await res.json() : [];
        } catch { todas = []; }
        filtrar();
    }

    function filtrar() {
        const busca  = document.getElementById('pc-busca').value.toLowerCase();
        const status = document.getElementById('pc-status').value;
        const agora  = new Date();

        const lista = todas
            .filter(c => {
                const dt = new Date(c.scheduleDate);
                return dt >= agora || c.status === 'Confirmada' || c.status === 'Pendente' || c.status === 'Reagendamento Solicitado';
            })
            .filter(c => !busca || (c.psicologoNome||'').toLowerCase().includes(busca) || (c.title||'').toLowerCase().includes(busca))
            .filter(c => !status || c.status === status)
            .sort((a, b) => new Date(a.scheduleDate) - new Date(b.scheduleDate));

        renderizar(lista);
    }

    function renderizar(lista) {
        const proximas = lista.filter(c => c.status === 'Confirmada' || c.status === 'Pendente').length;
        document.getElementById('pc-sub').textContent =
            `${proximas} consulta${proximas !== 1 ? 's' : ''} próxima${proximas !== 1 ? 's' : ''}`;

        if (!lista.length) {
            document.getElementById('pc-tbody').innerHTML =
                `<tr><td colspan="4" style="text-align:center;padding:32px;color:#9ca3af">Nenhuma consulta encontrada.</td></tr>`;
            return;
        }

        document.getElementById('pc-tbody').innerHTML = lista.map(c => {
            const dt = new Date(c.scheduleDate);
            const nome = c.psicologoNome || 'Psicólogo(a)';
            const dataHora = `${dt.toLocaleDateString('pt-BR')} <span style="color:#9ca3af">${dt.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})} · ${c.durationMinutes}min</span>`;
            return `<tr>
                <td>
                    <div class="adm-user-cell">
                        <div class="av" style="background:${avatarColor(nome)}">${initials(nome)}</div>
                        <div class="info"><strong>${nome}</strong></div>
                    </div>
                </td>
                <td>${dataHora}</td>
                <td><span class="adm-badge ${STATUS_BADGE[c.status]||'adm-badge-gray'}">${c.status}</span></td>
                <td style="text-align:right">
                    <button class="adm-icon-btn" onclick='abrirDetalhe(${JSON.stringify(c).replace(/'/g,"&apos;")})'>
                        <i class="ti ti-eye"></i>
                    </button>
                </td>
            </tr>`;
        }).join('');
    }

    function abrirDetalhe(c) {
        const dt = new Date(c.scheduleDate);
        const podeCancel = c.status !== 'Cancelada' && c.status !== 'Finalizado';

        document.getElementById('detalhe-corpo').innerHTML = `
            <div class="adm-detail-row"><span class="adm-detail-label">Psicólogo(a)</span><span class="adm-detail-value">${c.psicologoNome || '—'}</span></div>
            <div class="adm-detail-row"><span class="adm-detail-label">Data</span><span class="adm-detail-value">${dt.toLocaleDateString('pt-BR')}</span></div>
            <div class="adm-detail-row"><span class="adm-detail-label">Horário</span><span class="adm-detail-value">${dt.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})} · ${c.durationMinutes} min</span></div>
            <div class="adm-detail-row"><span class="adm-detail-label">Status</span><span class="adm-detail-value"><span class="adm-badge ${STATUS_BADGE[c.status]||'adm-badge-gray'}">${c.status}</span></span></div>
        `;

        document.getElementById('detalhe-acoes').innerHTML = podeCancel
            ? `<button class="adm-btn adm-btn-danger" style="flex:1;justify-content:center" onclick="cancelar('${c.calendarId}')">
                   <i class="ti ti-x"></i> Cancelar consulta
               </button>`
            : '';

        openModal('modal-detalhe');
    }

    async function cancelar(id) {
        if (!confirm('Confirma o cancelamento desta consulta?')) return;
        const res = await fetch(`/api/PacienteAgenda/${id}/cancel`, { method: 'PATCH', credentials: 'include' });
        if (res.ok) {
            showToast('Consulta cancelada.');
            closeModal('modal-detalhe');
            await carregar();
        } else {
            const err = await res.json().catch(() => ({}));
            showToast(err.message || 'Erro ao cancelar.', false);
        }
    }

    function aplicarMascaraData(input) {
        let v = input.value.replace(/\D/g, '').substring(0, 8);
        if (v.length > 4) v = v.substring(0,2) + '/' + v.substring(2,4) + '/' + v.substring(4);
        else if (v.length > 2) v = v.substring(0,2) + '/' + v.substring(2);
        input.value = v;
    }

    function dataBrParaIso(dataBr) {
        const partes = dataBr.split('/');
        if (partes.length !== 3 || partes[2].length !== 4) return null;
        return `${partes[2]}-${partes[1].padStart(2,'0')}-${partes[0].padStart(2,'0')}`;
    }

    async function abrirNovaConsulta() {
        const sel = document.getElementById('nova-psicologo');
        sel.innerHTML = '<option value="">Carregando...</option>';

        const res = await fetch('/api/PacienteAgenda/psicologos', { credentials: 'include' });
        if (res.ok) {
            const lista = await res.json();
            sel.innerHTML = '<option value="">Selecione um psicólogo...</option>' +
                lista.map(p => `<option value="${p.id}">${p.nome}</option>`).join('');
        } else {
            sel.innerHTML = '<option value="">Erro ao carregar</option>';
        }

        document.getElementById('nova-data').value = '';
        document.getElementById('nova-hora').value = '';

        openModal('modal-nova');
    }

    async function salvarConsulta() {
        const psicologoId = document.getElementById('nova-psicologo').value;
        const dataBr      = document.getElementById('nova-data').value;
        const hora        = document.getElementById('nova-hora').value;
        const data        = dataBrParaIso(dataBr);

        if (!psicologoId) return showToast('Selecione um psicólogo.', false);
        if (!dataBr || dataBr.length < 10) return showToast('Informe a data no formato dd/mm/aaaa.', false);
        if (!data)        return showToast('Data inválida.', false);
        if (!hora)        return showToast('Informe o horário.', false);

        if (hora < '07:00' || hora >= '19:00')
            return showToast('Horário deve ser entre 07:00 e 19:00.', false);

        const res = await fetch('/api/PacienteAgenda', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({
                psicologoId,
                scheduleDate: `${data}T${hora}:00`,
                durationMinutes: 60
            })
        });

        if (res.ok) {
            showToast('Consulta agendada com sucesso!');
            closeModal('modal-nova');
            await carregar();
        } else {
            const err = await res.json().catch(() => ({}));
            showToast(err.message || 'Erro ao agendar.', false);
        }
    }

    carregar();
</script>
}
