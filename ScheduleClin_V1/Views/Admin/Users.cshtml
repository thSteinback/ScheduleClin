@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"]      = "Usuários";
    ViewData["ActiveMenu"] = "usuarios";
}

<div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:6px">
    <div>
        <div class="adm-page-title">Usuários</div>
        <div class="adm-page-sub" id="sub-count">Carregando...</div>
    </div>
    <button class="adm-btn adm-btn-primary" onclick="abrirModalNovo()">
        <i class="ti ti-plus"></i> Novo usuário
    </button>
</div>

<!-- busca + filtro -->
<div class="adm-search-wrap">
    <div class="adm-search">
        <i class="ti ti-search"></i>
        <input type="text" id="inp-busca" placeholder="Buscar por nome ou e-mail..." oninput="filtrar()" />
    </div>
    <select class="adm-input" style="width:160px" id="sel-perfil" onchange="filtrar()">
        <option value="">Todos os perfis</option>
        <option value="Administrador">Administrador</option>
        <option value="Psicóloga(o)">Psicóloga(o)</option>
        <option value="Paciente">Paciente</option>
    </select>
</div>

<div class="adm-card">
    <table class="adm-table">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Telefone</th>
                <th>Perfil</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody id="tbody-usuarios">
            <tr><td colspan="5" style="text-align:center;padding:32px;color:#9ca3af">Carregando...</td></tr>
        </tbody>
    </table>
</div>

<!-- ── MODAL NOVO USUÁRIO ── -->
<div class="adm-modal-bg" id="modal-novo-usuario">
    <div class="adm-modal">
        <div class="adm-modal-head">
            <h3>Novo Usuário</h3>
            <button class="adm-modal-close" onclick="closeModal('modal-novo-usuario')">
                <i class="ti ti-x"></i>
            </button>
        </div>

        <div class="adm-field">
            <label>Nome completo *</label>
            <input class="adm-input" id="nu-nome" placeholder="Nome do usuário" />
        </div>
        <div class="adm-field">
            <label>E-mail *</label>
            <input class="adm-input" id="nu-email" type="email" placeholder="email@clinica.com" />
        </div>
        <div class="adm-field">
            <label>CPF *</label>
            <input class="adm-input" id="nu-cpf" placeholder="000.000.000-00" maxlength="14" oninput="aplicarMascaraCpf(this)" />
        </div>
        <div class="adm-field">
            <label>Data de nascimento *</label>
            <input class="adm-input" id="nu-nasc" placeholder="dd/mm/aaaa" maxlength="10" oninput="aplicarMascaraData(this)" />
        </div>
        <div class="adm-field">
            <label>Perfil *</label>
            <select class="adm-input" id="nu-perfil" onchange="atualizarCamposPerfil()">
                <option value="">Selecione...</option>
            </select>
        </div>
        <div class="adm-field" id="nu-crp-group" style="display:none">
            <label>CRP *</label>
            <input class="adm-input" id="nu-crp" placeholder="00/000000" maxlength="9" oninput="aplicarMascaraCrp(this)" />
        </div>

        <div id="nu-erro" style="font-size:13px;color:#b91c1c;margin-bottom:12px;display:none"></div>

        <div class="adm-modal-footer">
            <button class="adm-btn" onclick="closeModal('modal-novo-usuario')">Cancelar</button>
            <button class="adm-btn adm-btn-primary" id="btn-adicionar-usuario" onclick="criarUsuario()">
                Adicionar
            </button>
        </div>
    </div>
</div>

<!-- ── MODAL EDITAR USUÁRIO ── -->
<div class="adm-modal-bg" id="modal-editar-usuario">
    <div class="adm-modal">
        <div class="adm-modal-head">
            <h3>Editar Usuário</h3>
            <button class="adm-modal-close" onclick="closeModal('modal-editar-usuario')">
                <i class="ti ti-x"></i>
            </button>
        </div>
        <input type="hidden" id="ed-id" />
        <div class="adm-field">
            <label>Nome completo</label>
            <input class="adm-input" id="ed-nome" />
        </div>
        <div class="adm-field">
            <label>E-mail</label>
            <input class="adm-input" id="ed-email" type="email" />
        </div>
        <div class="adm-field" id="ed-crp-group" style="display:none">
            <label>CRP</label>
            <input class="adm-input" id="ed-crp" placeholder="00/000000" maxlength="9" oninput="aplicarMascaraCrp(this)" />
        </div>
        <div class="adm-field">
            <label>CPF</label>
            <input class="adm-input" id="ed-cpf" maxlength="14" oninput="aplicarMascaraCpf(this)" />
        </div>
        <div class="adm-field">
            <label>Data de nascimento</label>
            <input class="adm-input" id="ed-nasc" placeholder="dd/mm/aaaa" maxlength="10" oninput="aplicarMascaraData(this)" />
        </div>
        <div id="ed-erro" style="font-size:13px;color:#b91c1c;margin-bottom:12px;display:none"></div>
        <div class="adm-modal-footer">
            <button class="adm-btn" onclick="closeModal('modal-editar-usuario')">Cancelar</button>
            <button class="adm-btn adm-btn-primary" onclick="salvarEdicao()">Salvar</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
const PERFIL_MAP = {
    'gestor':    { label: 'Administrador', cls: 'adm-badge-blue'   },
    'psicologo': { label: 'Psicóloga(o)', cls: 'adm-badge-purple' },
    'paciente':  { label: 'Paciente',      cls: 'adm-badge-gray'   },
};

const PERFIL_LABELS = {
    Psicologo: 'Psicólogo(a)',
    Paciente:  'Paciente',
};

const PROFILE_IDS = {
    Psicologo: '5ca54613-fdba-492c-b28a-0a72750fba62',
    Paciente:  '75c5eb4a-b28a-4ec6-a437-8a16b02e37df',
};

let todosUsuarios = [];
let perfisCadastro = [];

function aplicarMascaraCpf(input) {
    let v = input.value.replace(/\D/g, '').slice(0, 11);
    v = v.replace(/(\d{3})(\d)/, '$1.$2')
         .replace(/(\d{3})(\d)/, '$1.$2')
         .replace(/(\d{3})(\d{1,2})$/, '$1-$2');
    input.value = v;
}

function aplicarMascaraCrp(input) {
    let v = input.value.replace(/\D/g, '').slice(0, 8);
    v = v.replace(/(\d{2})(\d)/, '$1/$2');
    input.value = v;
}

function aplicarMascaraData(input) {
    let v = input.value.replace(/\D/g, '').slice(0, 8);
    v = v.replace(/(\d{2})(\d)/, '$1/$2')
         .replace(/(\d{2})(\d)/, '$1/$2');
    input.value = v;
}

// "dd/mm/aaaa" -> "yyyy-MM-dd" (ISO, sem hora) — null se inválida/incompleta
function dataBrParaIso(dataBr) {
    const m = /^(\d{2})\/(\d{2})\/(\d{4})$/.exec(dataBr || '');
    if (!m) return null;
    const [, dia, mes, ano] = m;
    return `${ano}-${mes}-${dia}`;
}

// Date (ou string ISO) -> "dd/mm/aaaa"
function isoParaDataBr(data) {
    const dt = new Date(data);
    if (isNaN(dt)) return '';
    const pad = n => String(n).padStart(2, '0');
    return `${pad(dt.getDate())}/${pad(dt.getMonth() + 1)}/${dt.getFullYear()}`;
}

function resolvePerfil(u) {
    const r = (u.role || u.perfilNome || '').toLowerCase();
    return PERFIL_MAP[r] || { label: u.perfilNome || u.role || '–', cls: 'adm-badge-gray' };
}

async function carregarPerfis() {
    try {
        const res = await fetch('/api/User/profiles', { credentials: 'include' });
        if (res.ok) perfisCadastro = await res.json();
    } catch { /* fallback abaixo */ }

    if (!perfisCadastro.length) {
        perfisCadastro = [
            { profileId: PROFILE_IDS.Psicologo, name: 'Psicologo' },
            { profileId: PROFILE_IDS.Paciente,  name: 'Paciente'  },
        ];
    }

    const sel = document.getElementById('nu-perfil');
    sel.innerHTML = '<option value="">Selecione...</option>' +
        perfisCadastro.map(p =>
            `<option value="${p.profileId}" data-name="${p.name}">${PERFIL_LABELS[p.name] || p.name}</option>`
        ).join('');
}

function perfilSelecionado() {
    const sel = document.getElementById('nu-perfil');
    const opt = sel.options[sel.selectedIndex];
    return {
        id:   sel.value,
        name: opt?.dataset?.name || '',
    };
}

function atualizarCamposPerfil() {
    const { name } = perfilSelecionado();
    const crpGroup = document.getElementById('nu-crp-group');
    const isPsicologo = name === 'Psicologo';

    crpGroup.style.display = isPsicologo ? 'block' : 'none';
    if (!isPsicologo) document.getElementById('nu-crp').value = '';
}

function abrirModalNovo(perfilPadrao) {
    document.getElementById('nu-nome').value  = '';
    document.getElementById('nu-email').value = '';
    document.getElementById('nu-cpf').value   = '';
    document.getElementById('nu-nasc').value  = '';
    document.getElementById('nu-crp').value   = '';
    document.getElementById('nu-erro').style.display = 'none';

    const sel = document.getElementById('nu-perfil');
    if (perfilPadrao) {
        const opt = [...sel.options].find(o => o.dataset.name === perfilPadrao);
        sel.value = opt ? opt.value : '';
    } else {
        sel.value = '';
    }
    atualizarCamposPerfil();
    openModal('modal-novo-usuario');
}

async function criarUsuario() {
    const nome  = document.getElementById('nu-nome').value.trim();
    const email = document.getElementById('nu-email').value.trim();
    const cpf   = document.getElementById('nu-cpf').value.trim();
    const nasc  = document.getElementById('nu-nasc').value;
    const crp   = document.getElementById('nu-crp').value.trim();
    const { id: perfilId, name: perfilNome } = perfilSelecionado();
    const erroEl = document.getElementById('nu-erro');

    if (!nome || !email || !cpf || !nasc) {
        erroEl.textContent = 'Nome, e-mail, CPF, data de nascimento e Perfil são obrigatórios.';
        erroEl.style.display = 'block';
        return;
    }
    if (!perfilId) {
        erroEl.textContent = 'Selecione um perfil.';
        erroEl.style.display = 'block';
        return;
    }
    if (perfilNome === 'Psicologo' && !crp) {
        erroEl.textContent = 'Informe o CRP do psicólogo(a).';
        erroEl.style.display = 'block';
        return;
    }
    const dataIso = dataBrParaIso(nasc);
    if (!dataIso) {
        erroEl.textContent = 'Data de nascimento inválida. Use o formato dd/mm/aaaa.';
        erroEl.style.display = 'block';
        return;
    }
    erroEl.style.display = 'none';

    const body = {
        userName:       nome,
        email:          email,
        cpf:            cpf,
        perfilId:       perfilId,
        dataNascimento: `${dataIso}T00:00:00`,
        crp:            perfilNome === 'Psicologo' ? crp : null,
    };

    const btn = document.getElementById('btn-adicionar-usuario');
    btn.disabled = true;
    btn.textContent = 'Adicionando...';

    try {
        const res = await fetch('/api/User', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify(body)
        });
        const data = await res.json();

        if (!res.ok) {
            const msg = Array.isArray(data) ? data.join(', ') : (data.message || 'Erro ao criar usuário.');
            erroEl.textContent = msg;
            erroEl.style.display = 'block';
            return;
        }

        closeModal('modal-novo-usuario');
        showToast(`Usuário ${nome} criado. Senha provisória: ${data.senhaProvisoria}`);
        await carregarUsuarios();
    } catch {
        erroEl.textContent = 'Erro de conexão.';
        erroEl.style.display = 'block';
    } finally {
        btn.disabled = false;
        btn.textContent = 'Adicionar';
    }
}

async function carregarUsuarios() {
    try {
        const res = await fetch('/get-users', { credentials: 'include' });
        if (!res.ok) throw new Error(res.status);
        todosUsuarios = await res.json();
        renderizar(todosUsuarios);
    } catch {
        document.getElementById('tbody-usuarios').innerHTML =
            `<tr><td colspan="5" style="text-align:center;padding:32px;color:#b91c1c">
                Erro ao carregar usuários. Verifique se você está autenticado.
             </td></tr>`;
    }
}

function renderizar(lista) {
    document.getElementById('sub-count').textContent = `${lista.length} usuário${lista.length !== 1 ? 's' : ''} no sistema`;

    if (!lista.length) {
        document.getElementById('tbody-usuarios').innerHTML =
            `<tr><td colspan="5" style="text-align:center;padding:32px;color:#9ca3af">Nenhum usuário encontrado.</td></tr>`;
        return;
    }

    const initials = n => (n||'??').split(/\s+/).slice(0,2).map(p=>p[0]).join('').toUpperCase();
    const COLORS = ['#2563eb','#0f766e','#7c3aed','#b45309','#be185d','#0369a1'];
    const avColor = n => { let h=0; for(let c of(n||''))h=(h*31+c.charCodeAt(0))&0xffff; return COLORS[h%COLORS.length]; };

    const rows = lista.map(u => {
        const perfil = resolvePerfil(u);
        const nome   = u.userName || u.email || '–';
        const isGestor = perfil.label === 'Administrador';

        return `<tr id="row-${u.id}" class="${u.active ? '' : 'row-inativo'}">
            <td>
                <div class="adm-user-cell">
                    <div class="av" style="background:${avColor(nome)}">${initials(nome)}</div>
                    <div class="info">
                        <strong>${nome}</strong>
                        <span>${u.email || ''}</span>
                    </div>
                </div>
            </td>
            <td style="color:#6b7280">—</td>
            <td><span class="adm-badge ${perfil.cls}">${perfil.label}</span></td>
            <td>
                ${isGestor
                    ? '<span style="color:#9ca3af">—</span>'
                    : `<div style="display:flex;align-items:center;gap:8px">
                          <label class="adm-toggle">
                              <input type="checkbox" ${u.active ? 'checked' : ''}
                                     onchange="toggleStatus('${u.id}', this)" />
                              <span class="adm-toggle-slider"></span>
                          </label>
                          <span id="lbl-${u.id}" style="font-size:13px;color:#6b7280">
                              ${u.active ? 'Ativo' : 'Inativo'}
                          </span>
                       </div>`
                }
            </td>
            <td style="text-align:right">
                ${isGestor ? '' : `<button class="adm-icon-btn" title="Editar" onclick='abrirEdicao(${JSON.stringify(u).replace(/'/g, "&apos;")})'>
                    <i class="ti ti-pencil"></i>
                </button>`}
            </td>
        </tr>`;
    });

    document.getElementById('tbody-usuarios').innerHTML = rows.join('');
}

function filtrar() {
    const busca  = document.getElementById('inp-busca').value.toLowerCase();
    const perfil = document.getElementById('sel-perfil').value.toLowerCase();

    const filtrado = todosUsuarios.filter(u => {
        const nome = (u.userName || u.email || '').toLowerCase();
        const p    = resolvePerfil(u).label.toLowerCase();
        return (!busca  || nome.includes(busca))
            && (!perfil || p.includes(perfil.replace('psicóloga(o)', 'psic')));
    });
    renderizar(filtrado);
}

async function toggleStatus(id, checkbox) {
    const novoStatus = checkbox.checked;
    const row = document.getElementById('row-' + id);
    const lbl = document.getElementById('lbl-' + id);

    try {
        const res = await fetch(`/api/User/${id}/status`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ isActive: novoStatus })
        });

        if (!res.ok) throw new Error();

        row.classList.toggle('row-inativo', !novoStatus);
        lbl.textContent = novoStatus ? 'Ativo' : 'Inativo';

        const u = todosUsuarios.find(x => x.id === id);
        if (u) u.active = novoStatus;

        showToast(novoStatus ? 'Usuário ativado.' : 'Usuário inativado.');
    } catch {
        checkbox.checked = !novoStatus;
        showToast('Erro ao alterar status.', false);
    }
}

function abrirEdicao(u) {
    const isPsicologo = (u.role || u.perfilNome || '').toLowerCase() === 'psicologo';

    document.getElementById('ed-id').value    = u.id;
    document.getElementById('ed-nome').value  = u.userName || '';
    document.getElementById('ed-email').value = u.email    || '';
    document.getElementById('ed-cpf').value   = u.cpf      || '';
    document.getElementById('ed-nasc').value  = u.dataNascimento
        ? isoParaDataBr(u.dataNascimento) : '';

    document.getElementById('ed-crp-group').style.display = isPsicologo ? 'block' : 'none';
    document.getElementById('ed-crp').value = u.crp || '';

    document.getElementById('ed-erro').style.display = 'none';
    openModal('modal-editar-usuario');
}

async function salvarEdicao() {
    const id    = document.getElementById('ed-id').value;
    const nome  = document.getElementById('ed-nome').value.trim();
    const email = document.getElementById('ed-email').value.trim();
    const crp   = document.getElementById('ed-crp').value.trim();
    const cpf   = document.getElementById('ed-cpf').value.trim();
    const nasc  = document.getElementById('ed-nasc').value;
    const erroEl = document.getElementById('ed-erro');

    const dataIso = nasc ? dataBrParaIso(nasc) : null;
    if (nasc && !dataIso) {
        erroEl.textContent = 'Data de nascimento inválida. Use o formato dd/mm/aaaa.';
        erroEl.style.display = 'block';
        return;
    }
    erroEl.style.display = 'none';

    const body = {
        userName:       nome   || undefined,
        email:          email  || undefined,
        cpf:            cpf    || undefined,
        crp:            document.getElementById('ed-crp-group').style.display !== 'none' ? crp : undefined,
        dataNascimento: dataIso ? `${dataIso}T00:00:00` : undefined,
    };

    try {
        const res = await fetch(`/api/User/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify(body)
        });

        if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            erroEl.textContent = data.message || 'Erro ao salvar.';
            erroEl.style.display = 'block';
            return;
        }

        closeModal('modal-editar-usuario');
        showToast('Usuário atualizado.');
        await carregarUsuarios();
    } catch {
        erroEl.textContent = 'Erro de conexão.';
        erroEl.style.display = 'block';
    }
}

(async () => {
    await carregarPerfis();
    await carregarUsuarios();
})();
</script>
}
