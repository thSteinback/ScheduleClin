@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"]      = "Agenda Geral";
    ViewData["ActiveMenu"] = "agenda";
}

<style>
    .cal-toolbar { display:flex; align-items:center; justify-content:space-between; margin-bottom:18px; flex-wrap:wrap; gap:10px; }
    .cal-nav { display:flex; align-items:center; gap:10px; }
    .cal-nav-label { font-size:14px; font-weight:600; color:#111827; min-width:230px; text-align:center; }

    .cal-grid { display:grid; grid-template-columns: 56px repeat(6, 1fr); }
    .cal-head-cell {
        text-align:center; padding:10px 4px; font-size:12px; color:#6b7280;
        border-bottom:1px solid #e8eaf0; background:#fafbfc;
    }
    .cal-head-cell.today { color:#fff; }
    .cal-head-day { font-weight:600; }
    .cal-head-num {
        display:inline-flex; align-items:center; justify-content:center;
        width:24px; height:24px; border-radius:50%; margin-top:2px; font-weight:600; color:#111827;
    }
    .cal-head-cell.today .cal-head-num { background:#2563eb; color:#fff; }

    .cal-hour-col { border-right:1px solid #e8eaf0; }
    .cal-hour-label {
        height:56px; font-size:11px; color:#9ca3af; text-align:right; padding-right:6px;
        border-bottom:1px solid #f3f4f6; position:relative; top:-7px;
    }

    .cal-day-col { position:relative; border-right:1px solid #f3f4f6; background-image: repeating-linear-gradient(#f3f4f6 0 1px, transparent 1px 56px); }

    .cal-chip {
        position:absolute; left:4px; right:4px; border-radius:6px;
        border-left:3px solid #2563eb; background:#eff6ff; color:#1d4ed8;
        font-size:12px; padding:4px 6px; overflow:hidden; cursor:pointer;
        box-shadow:0 1px 2px rgba(0,0,0,.06);
    }
    .cal-chip.cal-chip-block { border-left-color:#9ca3af; background:#f3f4f6; color:#6b7280; }
    .cal-chip:hover { filter:brightness(.97); }
</style>

<div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:6px">
    <div>
        <div class="adm-page-title">Agenda Geral</div>
        <div class="adm-page-sub">Todos os agendamentos da clínica</div>
    </div>
    <button class="adm-btn adm-btn-primary" onclick="abrirModalNovaConsulta()">
        <i class="ti ti-plus"></i> Nova consulta
    </button>
</div>

<div class="cal-toolbar">
    <div class="cal-nav">
        <button class="adm-icon-btn" onclick="mudarSemana(-1)"><i class="ti ti-chevron-left"></i></button>
        <button class="adm-icon-btn" onclick="mudarSemana(1)"><i class="ti ti-chevron-right"></i></button>
        <span class="cal-nav-label" id="cal-label"></span>
    </div>
    <button class="adm-btn" onclick="irParaHoje()">Hoje</button>
</div>

<div class="adm-card" style="padding:0">
    <div class="cal-grid" id="cal-head"></div>
    <div class="cal-grid" id="cal-body" style="height:728px"></div>
</div>

@await Html.PartialAsync("_ModalQueries")

@section Scripts {
<script>
    const HORA_INICIO = 7;
    const HORA_FIM = 19;
    const ALTURA_HORA = 56;
    const DIAS_SEMANA = ['Seg','Ter','Qua','Qui','Sex','Sáb'];

    let inicioSemana = inicioDaSemana(new Date());
    let consultasSemana = [];

    function inicioDaSemana(data) {
        const d = new Date(data);
        const diff = (d.getDay() + 6) % 7; // 0 = segunda
        d.setDate(d.getDate() - diff);
        d.setHours(0,0,0,0);
        return d;
    }

    function mudarSemana(delta) {
        inicioSemana.setDate(inicioSemana.getDate() + delta * 7);
        carregarAgenda();
    }

    function irParaHoje() {
        inicioSemana = inicioDaSemana(new Date());
        carregarAgenda();
    }

    function renderHead() {
        const hoje = new Date(); hoje.setHours(0,0,0,0);
        let html = '<div class="cal-head-cell"></div>';
        for (let i = 0; i < 6; i++) {
            const dia = new Date(inicioSemana); dia.setDate(dia.getDate() + i);
            const isHoje = dia.getTime() === hoje.getTime();
            html += `<div class="cal-head-cell ${isHoje ? 'today' : ''}">
                <div class="cal-head-day">${DIAS_SEMANA[i]}</div>
                <div class="cal-head-num">${dia.getDate()}</div>
            </div>`;
        }
        document.getElementById('cal-head').innerHTML = html;

        const fimSemana = new Date(inicioSemana); fimSemana.setDate(fimSemana.getDate() + 5);
        const fmt = d => d.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long' });
        document.getElementById('cal-label').textContent = `${fmt(inicioSemana)} – ${fmt(fimSemana)} de ${fimSemana.getFullYear()}`;
    }

    function renderBody() {
        let html = '<div class="cal-hour-col">';
        for (let h = HORA_INICIO; h <= HORA_FIM; h++) {
            html += `<div class="cal-hour-label">${String(h).padStart(2,'0')}:00</div>`;
        }
        html += '</div>';

        for (let i = 0; i < 6; i++) {
            const dia = new Date(inicioSemana); dia.setDate(dia.getDate() + i);
            const doDia = consultasSemana.filter(c => {
                const dt = new Date(c.scheduleDate);
                return dt.getFullYear() === dia.getFullYear() && dt.getMonth() === dia.getMonth() && dt.getDate() === dia.getDate();
            });

            let chips = '';
            doDia.forEach(c => {
                const dt = new Date(c.scheduleDate);
                const minutosDoInicio = (dt.getHours() - HORA_INICIO) * 60 + dt.getMinutes();
                const top = (minutosDoInicio / 60) * ALTURA_HORA;
                const altura = Math.max((c.durationMinutes / 60) * ALTURA_HORA, 22);
                const isBloqueio = !c.pacienteId;
                const nome = c.pacienteNome || c.title;

                chips += `<div class="cal-chip ${isBloqueio ? 'cal-chip-block' : ''}"
                    style="top:${top}px;height:${altura}px"
                    onclick='abrirDetalhesConsulta(${JSON.stringify(c).replace(/'/g, "&apos;")})'>
                    ${isBloqueio ? '<i class="ti ti-lock" style="font-size:11px;margin-right:3px"></i>' : ''}${nome}
                </div>`;
            });

            html += `<div class="cal-day-col" style="height:${(HORA_FIM - HORA_INICIO + 1) * ALTURA_HORA}px">${chips}</div>`;
        }

        document.getElementById('cal-body').innerHTML = html;
    }

    async function carregarAgenda() {
        renderHead();

        const fim = new Date(inicioSemana); fim.setDate(fim.getDate() + 6);
        try {
            const res = await fetch(`/api/Calendar?inicio=${dataLocalStr(inicioSemana)}T00:00:00&fim=${dataLocalStr(fim)}T23:59:59`, { credentials: 'include' });
            consultasSemana = res.ok ? await res.json() : [];
        } catch {
            consultasSemana = [];
        }

        renderBody();
    }

    window.onConsultaAtualizada = function (dataConsultaIso) {
        if (dataConsultaIso) inicioSemana = inicioDaSemana(new Date(dataConsultaIso));
        return carregarAgenda();
    };

    (async () => {
        await carregarPacientesEPsicologos();
        await carregarAgenda();
    })();
</script>
}
