<!-- ── MODAL NOVA CONSULTA ── -->
<div class="adm-modal-bg" id="modal-nova-consulta">
    <div class="adm-modal">
        <div class="adm-modal-head">
            <h3>Nova Consulta</h3>
            <button class="adm-modal-close" onclick="closeModal('modal-nova-consulta')">
                <i class="ti ti-x"></i>
            </button>
        </div>

        <div class="adm-field">
            <label>Paciente</label>
            <select class="adm-input" id="nc-paciente">
                <option value="">Selecione...</option>
            </select>
        </div>
        <div class="adm-field">
            <label>Psicólogo(a)</label>
            <select class="adm-input" id="nc-psicologo">
                <option value="">Selecione...</option>
            </select>
        </div>
        <div class="adm-field">
            <label>Título (opcional)</label>
            <input class="adm-input" id="nc-titulo" placeholder="Ex.: Consulta de retorno" />
        </div>
        <div class="adm-field">
            <label>Data</label>
            <input class="adm-input" id="nc-data" type="date" />
        </div>
        <div class="adm-field">
            <label>Hora</label>
            <input class="adm-input" id="nc-hora" type="time" />
        </div>
        <div class="adm-field">
            <label>Duração (min)</label>
            <input class="adm-input" id="nc-duracao" type="number" min="15" step="15" value="60" />
        </div>

        <div id="nc-erro" style="font-size:13px;color:#b91c1c;margin-bottom:12px;display:none"></div>

        <div class="adm-modal-footer">
            <button class="adm-btn" onclick="closeModal('modal-nova-consulta')">Cancelar</button>
            <button class="adm-btn adm-btn-primary" id="btn-criar-consulta" onclick="criarConsulta()">
                Agendar
            </button>
        </div>
    </div>
</div>

<!-- ── MODAL DETALHES DA CONSULTA ── -->
<div class="adm-modal-bg" id="modal-detalhes-consulta">
    <div class="adm-modal">
        <div class="adm-modal-head">
            <h3>Detalhes da Consulta</h3>
            <button class="adm-modal-close" onclick="closeModal('modal-detalhes-consulta')">
                <i class="ti ti-x"></i>
            </button>
        </div>

        <div id="dc-visualizacao">
            <div style="border-left:3px solid #2563eb;background:#eff6ff;padding:10px 14px;border-radius:8px;margin-bottom:16px">
                <div id="dc-psicologo" style="font-size:11px;font-weight:700;letter-spacing:.4px;color:#2563eb;text-transform:uppercase"></div>
                <div id="dc-paciente" style="font-size:16px;font-weight:600;color:#111827"></div>
            </div>
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;color:#374151;font-size:14px">
                <i class="ti ti-calendar"></i> <span id="dc-data"></span>
            </div>
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;color:#374151;font-size:14px">
                <i class="ti ti-clock"></i> <span id="dc-hora"></span>
            </div>
            <div style="margin-bottom:20px"><span class="adm-badge" id="dc-status"></span></div>

            <div class="adm-modal-footer" style="flex-direction:column">
                <button class="adm-btn" style="justify-content:center" onclick="mostrarEdicaoConsulta('editar')">
                    <i class="ti ti-pencil"></i> Editar consulta
                </button>
                <button class="adm-btn" style="justify-content:center" onclick="mostrarEdicaoConsulta('reagendar')">
                    <i class="ti ti-clock-hour-4"></i> Reagendar
                </button>
                <button class="adm-btn" style="justify-content:center;background:#ef4444;color:#fff;border-color:#ef4444"
                        onclick="cancelarConsulta()">
                    <i class="ti ti-x"></i> Cancelar consulta
                </button>
            </div>
        </div>

        <div id="dc-edicao" style="display:none">
            <input type="hidden" id="ed-id" />

            <div class="adm-field" id="ed-titulo-group">
                <label>Título</label>
                <input class="adm-input" id="ed-titulo" />
            </div>
            <div class="adm-field" id="ed-psicologo-group">
                <label>Psicólogo(a)</label>
                <select class="adm-input" id="ed-psicologo"></select>
            </div>
            <div class="adm-field" id="ed-status-group">
                <label>Status</label>
                <select class="adm-input" id="ed-status">
                    <option value="Pendente">Pendente</option>
                    <option value="Confirmada">Confirmada</option>
                    <option value="Reagendamento Solicitado">Reagendamento Solicitado</option>
                </select>
            </div>
            <div class="adm-field">
                <label>Data</label>
                <input class="adm-input" id="ed-data" type="date" />
            </div>
            <div class="adm-field">
                <label>Hora</label>
                <input class="adm-input" id="ed-hora" type="time" />
            </div>
            <div class="adm-field">
                <label>Duração (min)</label>
                <input class="adm-input" id="ed-duracao" type="number" min="15" step="15" />
            </div>

            <div id="ed-erro" style="font-size:13px;color:#b91c1c;margin-bottom:12px;display:none"></div>

            <div class="adm-modal-footer">
                <button class="adm-btn" onclick="esconderEdicaoConsulta()">Voltar</button>
                <button class="adm-btn adm-btn-primary" onclick="salvarEdicaoConsulta()">Salvar</button>
            </div>
        </div>
    </div>
</div>

<script>
const STATUS_BADGE = {
    'Pendente':                  'adm-badge-orange',
    'Confirmada':                'adm-badge-green',
    'Reagendamento Solicitado':  'adm-badge-blue',
    'Cancelada':                 'adm-badge-red',
    'Finalizado':                'adm-badge-teal',
};

let pacientesCadastrados = [];
let psicologosCadastrados = [];
let consultaSelecionada = null;

// trabalha sempre com hora local "pura" (sem conversão de timezone) —
// data/hora digitada pelo usuário deve ser exatamente o que é salvo e exibido
const pad2 = n => String(n).padStart(2, '0');
const dataLocalStr = d => `${d.getFullYear()}-${pad2(d.getMonth() + 1)}-${pad2(d.getDate())}`;
const horaLocalStr = d => `${pad2(d.getHours())}:${pad2(d.getMinutes())}`;

// hook que cada página define para recarregar sua própria lista após criar/editar/cancelar
window.onConsultaAtualizada = window.onConsultaAtualizada || (() => {});

async function carregarPacientesEPsicologos() {
    try {
        const [resP, resQ] = await Promise.all([
            fetch('/api/Calendar/pacientes', { credentials: 'include' }),
            fetch('/api/Calendar/psicologos', { credentials: 'include' }),
        ]);
        pacientesCadastrados  = resP.ok ? await resP.json() : [];
        psicologosCadastrados = resQ.ok ? await resQ.json() : [];
    } catch {
        pacientesCadastrados = [];
        psicologosCadastrados = [];
    }

    const optsPaciente = pacientesCadastrados.map(p => `<option value="${p.id}">${p.nome}</option>`).join('');
    const optsPsicologo = psicologosCadastrados.map(p => `<option value="${p.id}">${p.nome}</option>`).join('');

    document.getElementById('nc-paciente').innerHTML  = '<option value="">Selecione...</option>' + optsPaciente;
    document.getElementById('nc-psicologo').innerHTML = '<option value="">Selecione...</option>' + optsPsicologo;
    document.getElementById('ed-psicologo').innerHTML = '<option value="">Selecione...</option>' + optsPsicologo;
}

async function abrirModalNovaConsulta() {
    document.getElementById('nc-paciente').value  = '';
    document.getElementById('nc-psicologo').value = '';
    document.getElementById('nc-titulo').value    = '';
    document.getElementById('nc-data').value      = dataLocalStr(new Date());
    document.getElementById('nc-hora').value      = '';
    document.getElementById('nc-duracao').value   = 60;
    document.getElementById('nc-erro').style.display = 'none';
    openModal('modal-nova-consulta');

    // se a lista ainda não carregou (ex.: clique muito rápido após o load da página), tenta de novo
    if (!pacientesCadastrados.length || !psicologosCadastrados.length) {
        await carregarPacientesEPsicologos();
    }
}

async function criarConsulta() {
    const pacienteId  = document.getElementById('nc-paciente').value;
    const psicologoId = document.getElementById('nc-psicologo').value;
    const titulo       = document.getElementById('nc-titulo').value.trim();
    const data          = document.getElementById('nc-data').value;
    const hora          = document.getElementById('nc-hora').value;
    const duracao       = parseInt(document.getElementById('nc-duracao').value, 10) || 60;
    const erroEl = document.getElementById('nc-erro');

    if (!pacienteId || !psicologoId || !data || !hora) {
        erroEl.textContent = 'Paciente, psicólogo(a), data e hora são obrigatórios.';
        erroEl.style.display = 'block';
        return;
    }
    if (hora < '07:00' || hora >= '20:00') {
        erroEl.textContent = 'Só é possível agendar consultas entre 07:00 e 19:59.';
        erroEl.style.display = 'block';
        return;
    }

    const pacienteNome = pacientesCadastrados.find(p => p.id === pacienteId)?.nome || 'Paciente';

    const scheduleDate = `${data}T${hora}:00`;

    const body = {
        title:           titulo || `Consulta — ${pacienteNome}`,
        scheduleDate:    scheduleDate,
        durationMinutes: duracao,
        pacienteId:      pacienteId,
        psicologoId:     psicologoId,
    };

    try {
        const res = await fetch('/api/Calendar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify(body)
        });
        if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            erroEl.textContent = data.message || 'Erro ao agendar consulta.';
            erroEl.style.display = 'block';
            return;
        }

        closeModal('modal-nova-consulta');
        showToast('Consulta agendada.');
        window.onConsultaAtualizada(scheduleDate);
    } catch {
        erroEl.textContent = 'Erro de conexão.';
        erroEl.style.display = 'block';
    }
}

function abrirDetalhesConsulta(consulta) {
    consultaSelecionada = consulta;

    document.getElementById('dc-visualizacao').style.display = 'block';
    document.getElementById('dc-edicao').style.display = 'none';

    const dt = new Date(consulta.scheduleDate);

    document.getElementById('dc-psicologo').textContent = consulta.psicologoNome || '—';
    document.getElementById('dc-paciente').textContent  = consulta.pacienteNome || consulta.title;
    document.getElementById('dc-data').textContent = dt.toLocaleDateString('pt-BR');
    document.getElementById('dc-hora').textContent = `${dt.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' })} · ${consulta.durationMinutes} min`;

    const statusEl = document.getElementById('dc-status');
    statusEl.textContent = consulta.status;
    statusEl.className = 'adm-badge ' + (STATUS_BADGE[consulta.status] || 'adm-badge-gray');

    openModal('modal-detalhes-consulta');
}

function mostrarEdicaoConsulta(modo) {
    if (!consultaSelecionada) return;

    document.getElementById('dc-visualizacao').style.display = 'none';
    document.getElementById('dc-edicao').style.display = 'block';
    document.getElementById('ed-erro').style.display = 'none';

    const completo = modo === 'editar';
    document.getElementById('ed-titulo-group').style.display    = completo ? 'block' : 'none';
    document.getElementById('ed-psicologo-group').style.display = completo ? 'block' : 'none';
    document.getElementById('ed-status-group').style.display    = completo ? 'block' : 'none';

    const dt = new Date(consultaSelecionada.scheduleDate);
    document.getElementById('ed-id').value       = consultaSelecionada.calendarId;
    document.getElementById('ed-titulo').value   = consultaSelecionada.title || '';
    document.getElementById('ed-psicologo').value = consultaSelecionada.psicologoId || '';
    document.getElementById('ed-status').value   = consultaSelecionada.status;
    document.getElementById('ed-data').value     = dataLocalStr(dt);
    document.getElementById('ed-hora').value     = horaLocalStr(dt);
    document.getElementById('ed-duracao').value  = consultaSelecionada.durationMinutes;
}

function esconderEdicaoConsulta() {
    document.getElementById('dc-visualizacao').style.display = 'block';
    document.getElementById('dc-edicao').style.display = 'none';
}

async function salvarEdicaoConsulta() {
    const id      = document.getElementById('ed-id').value;
    const data    = document.getElementById('ed-data').value;
    const hora    = document.getElementById('ed-hora').value;
    const erroEl  = document.getElementById('ed-erro');

    if (data && hora && (hora < '07:00' || hora >= '20:00')) {
        erroEl.textContent = 'Só é possível agendar consultas entre 07:00 e 19:59.';
        erroEl.style.display = 'block';
        return;
    }

    const body = {
        title:           document.getElementById('ed-titulo-group').style.display !== 'none'
                              ? document.getElementById('ed-titulo').value.trim() : undefined,
        psicologoId:      document.getElementById('ed-psicologo-group').style.display !== 'none'
                              ? (document.getElementById('ed-psicologo').value || undefined) : undefined,
        status:           document.getElementById('ed-status-group').style.display !== 'none'
                              ? document.getElementById('ed-status').value : undefined,
        scheduleDate:     data && hora ? `${data}T${hora}:00` : undefined,
        durationMinutes:  parseInt(document.getElementById('ed-duracao').value, 10) || undefined,
    };

    try {
        const res = await fetch(`/api/Calendar/${id}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify(body)
        });
        if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            erroEl.textContent = data.message || 'Erro ao salvar.';
            erroEl.style.display = 'block';
            return;
        }

        closeModal('modal-detalhes-consulta');
        showToast('Consulta atualizada.');
        window.onConsultaAtualizada(body.scheduleDate);
    } catch {
        erroEl.textContent = 'Erro de conexão.';
        erroEl.style.display = 'block';
    }
}

async function cancelarConsulta() {
    if (!consultaSelecionada) return;
    if (!confirm('Cancelar esta consulta?')) return;

    try {
        const res = await fetch(`/api/Calendar/${consultaSelecionada.calendarId}/cancel`, {
            method: 'PATCH',
            credentials: 'include',
        });
        if (!res.ok) throw new Error();

        closeModal('modal-detalhes-consulta');
        showToast('Consulta cancelada.');
        window.onConsultaAtualizada();
    } catch {
        showToast('Erro ao cancelar consulta.', false);
    }
}
</script>
